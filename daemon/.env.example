# littleimpd daemon configuration
# Copy this file to .env and adjust values as needed

# Server host (default: 127.0.0.1 — localhost only)
HOST=127.0.0.1

# Server port (default: 3210)
PORT=3210

# Data directory for SQLite DB and other persistent files
# Default: ~/.local/share/littleimp
DATA_DIR=~/.local/share/littleimp

# Comma-separated list of allowed CORS origins (default: Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Log format: "pretty" (human-readable) or "json" (structured)
# Default: "pretty" in development, "json" in production
LOG_FORMAT=pretty

# Node/Bun environment
NODE_ENV=development

# ─── LLM enrichment (TASK-007) ────────────────────────────────────────────────
# Leave LLM_API_KEY empty to disable enrichment (bookmarks still fully usable).

# OpenAI (default)
#LLM_API_KEY=sk-...
#LLM_BASE_URL=https://api.openai.com/v1
#LLM_MODEL=gpt-4o-mini

# Ollama (local)
#LLM_API_KEY=
#LLM_BASE_URL=http://localhost:11434/v1
#LLM_MODEL=llama3

# ─── Embeddings (TASK-008) ────────────────────────────────────────────────────
# Defaults to LLM_API_KEY / LLM_BASE_URL if not set separately.
# Leave EMBEDDING_API_KEY empty (and LLM_API_KEY empty) to disable embedding.

# OpenAI (default)
#EMBEDDING_API_KEY=sk-...
#EMBEDDING_BASE_URL=https://api.openai.com/v1
#EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local, e.g. nomic-embed-text)
#EMBEDDING_API_KEY=
#EMBEDDING_BASE_URL=http://localhost:11434/v1
#EMBEDDING_MODEL=nomic-embed-text

# ─── Organization Agent (TASK-011) ────────────────────────────────────────────
# How often the autonomous organization agent runs (milliseconds).
# Default: 86400000 (24 hours). Set lower for testing (e.g. 60000 = 1 minute).
#AGENT_INTERVAL_MS=86400000
